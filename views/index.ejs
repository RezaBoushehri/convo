<%-include('partials/header.ejs') %>
<p style="display:none" id='roomID'><%=roomID%></p>
<p style="display:none" id='username'><%=username%></p>
<!-- <div id="alert" class="px-3"></div> -->

<div data-bs-theme="dark" id="main">
    <div id='roomInfo' class='me-3 row col-md-auto justify-content-end overflow-hidden'></div>
    <% if(typeof room !=='undefined'){ %>
            
            <!-- roomInfo -->
            <div class="modal fade" id="roomInfo_modal" tabindex="-1" role="dialog" aria-labelledby="" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-lg" role="document">
                    <div class="modal-content">
                        <!-- هدر مودال -->      
                        <div class="modal-header bg-primary text-white">        
                            <h5 class="modal-title" id="exampleModalLabel"><i class="bi bi-info-circle"></i> اطلاعات اتاق</h5>
                            <button type="button" class="close btn btn-close" data-bs-dismiss="modal" aria-label="Close">
                        </div>
                        <!-- بدنه مودال – فرم -->      
                        <div class="modal-body">        
                            <form id="roomInfoForm">
                            <!-- Room ID -->          
                                <div class="mb-3">            
                                    <label class="form-label">
                                        <i class="bi bi-hash"></i> شناسه
                                    </label>
                                    <div class="input-group">       
                                        <input type="text" dir="auto" class="form-control col" name="roomID" value="<%=room.roomID%>" readonly> 
                                        <button class="btn btn-outline-secondary col-auto" type="button" onclick="copyToClipboard('<%=room.roomID%>')">
                                        <i class="bi bi-copy"> رونوشت</i> 
                                        </button> 
                                        <a href="whatsapp://send?text=${href}/join/${data.room.roomID}" data-action="share/whatsapp/share" 
                                            class='col-auto btn btn-primary' onClick="javascript:window.open(this.href, '', 'menubar=no,toolbar=no,resizable=yes,scrollbars=yes,height=300,width=600');return false;" 
                                            target="_blank" title="Share on whatsapp" data-bs-toggle="tooltip" data-bs-placement="bottom">
                                            <i class='bi bi-whatsapp'> اشتراک گزاری</i>
                                        </a>    
                                    </div>        
                                </div>
                            <!-- Room Name -->          
                                <div class="mb-3">            
                                    <label class="form-label"><i class="bi bi-chat-left-text"></i> نام
                                    </label>            
                                    <input type="text" dir="auto" class="form-control" name="roomName" value="<%=room.roomName%>" readonly>          
                                </div>
                            <!-- Admin (شماره موبایل) -->          
                                <div class="mb-3">            
                                    <label class="form-label">
                                        <i class="bi bi-person-badge"></i> مدیر
                                    </label>            
                                    <span type="text" dir="auto" class="form-control" name="admin"></span>          
                                </div>
                            
                                     
                            
                                <div class="mb-3">

                                    <!-- تنظیمات (Setting) -->          
                                    <label id="room_settings_label" data-bs-toggle="collapse" data-bs-target="#room_settings" class="d-flex border form-label col-12 mb-0 rounded-bottom-0 btn text-secondary fs-5 justify-content-between">
                                        <span>
                                            <i class="bi bi-gear"></i> تنظیمات
                                        </span>
                                        <i class="icon bi bi-chevron-compact-down"></i>
                                    </label> 
                                    <div class="col-12">
                                        <div id="room_settings" class="mb-3 collapse border border-top-0 p-2 rounded-bottom">            
                                            <label class="form-label"><i class="bi bi-gear"></i> تنظیمات
                                            </label>            
                                            <input type="text" dir="auto" class="form-control" name="joinableUrl" value="<%=room?.settings?.joinableUrl%>" readonly>          
                                        </div>
                                    </div> 
                                </div>
                                <!-- اعضا (Members) -->          
                                <div class="mb-3"> 
                                    <div class="col-12 justify-content-between d-flex position-relative">
                                        <label class="form-label">
                                            <i class="bi bi-people"></i> اعضا
                                        </label>       
                                        <i class="bi bi-person-plus text-muted cursor-pointer" data-bs-toggle="collapse" data-bs-target="#addMember_room_modal" data-bs-parent> افزودن کاربر</i>  
                                    </div>   
                                    <div id="addMember_room_modal" class="collapse mb-3">
                                        <form   class="form-floating row g-3">
                                            <div class="input-group">
                                                <label class="input-group-text col-auto">
                                                    <i class="bi bi-person"> Username</i>
                                                </label>
                                                <input type="text" class="form-control col" name="phone"/>
                                                <button type="button" data-submit="true" class="btn btn-outline-primary" data-bs-dissmiss="collapse" > <i class="bi bi-plus-circle"> Add</i></button>
                                            </div>
                                        </form>   
                                    </div>        
                                    <ul class="list-group hide-scrollbar" id="membersList">              
                                                           
                                    </ul>          
                                </div>
                                <div class="col-12 row m-auto mb-3">
                                <!-- تاریخ ایجاد -->          
                                    <div class="col px-1">            
                                        <label class="form-label"><i class="bi bi-calendar-event"></i> تاریخ ایجاد
                                        </label>            
                                        <span  class="form-control" dir="auto" name="createdAt"readonly> 
                                            <%=new Date(room?.createdAt).toLocaleDateString('fa-IR', {year: 'numeric',month: 'short',day: 'numeric'})%>    
                                        </span>         
                                    </div>
                                <!-- تاریخ آخرین به‌روزرسانی -->          
                                    <div class="col px-1">            
                                        <label class="form-label">
                                            <i class="bi bi-clock-history"></i> تاریخ آخرین به‌روزرسانی 
                                        </label>            
                                        <span  class="form-control" dir="auto" name="lastUpdated"readonly> 
                                            <%=new Date(room?.lastUpdated).toLocaleDateString('fa-IR', {year: 'numeric',month: 'short',day: 'numeric'})%>    
                                        </span>                                     
                                    </div>
                                </div>
                            </form>      
                        </div>
                        
                        <!-- فوتر مودال -->
                        <div class="modal-footer">        
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">          
                                <i class="bi bi-x-circle"></i> بستن        
                            </button>  
                            <% if(room.admin == username){ %>
                            <button type="submit" class="btn btn-primary" data-bs-dismiss="modal">          
                                <i class="bi bi-check-circle"></i> تغییر دادن        
                            </button>  
                            <%}%>
                            
                        </div>
                    </div>
                </div>
            </div>
        <%}%>
    <div id="btns" class="mb-3">

        <div class="row col-12 p-0 gap-2 justify-content-center">
            <div class="col-md-6 col-auto">
                <div class="input-group">
                   <div class="input-group-text"><i class=" bi bi-search"></i> </div>
                   <input placeholder="Search title or room-id" id="search_roomList" class="form-control"/>
               </div>
            </div>
            <button class="btn btn-primary col-auto " data-bs-toggle="modal" data-bs-target="#joinRoom">پیوستن اتاق</button>
            <button class="btn btn-danger col-auto " data-bs-toggle="modal" data-bs-target="#createRoom">ساختن اتاق</button>
        </div>
        
        <!-- joinRoom -->
        <div class="modal fade" id="joinRoom" tabindex="-1" role="dialog" aria-labelledby="" aria-hidden="true">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="exampleModalLabel">پیوستن به اتاق</h5>
                        <button type="button" class="close btn btn-close" data-bs-dismiss="modal" aria-label="Close">
                        </button>
                    </div>
                    <div class="modal-body row justify-content-center">
                        <div class="input-group m-4">
                            <div class="input-group-prepend">
                                <div class="input-group-text">شناسه اتاق</div>
                            </div>
                            <input type="text" dir="auto" class="roomNameInput form-control" id="joinRoomName" placeholder="Room id">
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">بستن</button>
                        <button type="button" class="btn btn-primary" data-bs-dismiss="modal" onclick='joinRoom()'>پیوستن</button>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- createRoom -->
        <div class="modal fade" id="createRoom" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="exampleModalLabel">ساخت اتاق</h5>
                        <button type="button" class="close btn btn-close" data-bs-dismiss="modal" aria-label="Close">
                        </button>
                    </div>
                    <div class="modal-body row justify-content-center">
                        <div class="input-group m-4">
                            <div class="input-group-prepend">
                                <div class="input-group-text">نام اتاق</div>
                            </div>
                            <input type="text" class=" roomNameInput form-control" id="createRoomName" placeholder="Room name">
                        </div>
                        <div class="input-group m-4">
                            <div class="input-group-prepend">
                                <div class="input-group-text">اعضا اتاق</div>
                            </div>
                            <input type="text" class=" roomMembersInput form-control" id="createRoomMembers" placeholder="Room members">
                        </div>
                        <p class="text-muted">
                            اگر به یک گروه (2 نفر یا بیشتر) نیاز دارید، بین هر شناسه "،" اضافه کنید
                        </p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">بستن</button>
                        <button type="button" class="btn btn-primary" data-bs-dismiss="modal" onclick='createRoom()'>ساختن</button>
                    </div>
                </div>
            </div>
        </div>
        
    </div>
    
    <ul class="list-group rounded container overflow-auto h-50rem" id="roomList_ul">
        <!-- Tab panes will be inserted dynamically -->
    </ul>


    <!-- <div id="loadingChatWindow" class="d-flex align-items-center text-primary blurBack p-2 col-6 m-auto rounded d-none">
        <strong role="status">Loading...</strong>
        <div class="spinner-border ms-auto" aria-hidden="true"></div>
    </div> -->
    <div id="chat-window" class="rounded d-none  m-auto overflow-auto">

        <!-- <div id="alert" dir="auto" style=" text-align: center;"></div> -->
        <div id="headTag" class="col-12 row m-auto z-1" dir="auto" style=" text-align: center;"></div>
        <div id="output" class="container rounded overflow-y-auto overflow-x-hidden  vh-75 hide-scrollbar">
        </div>

        <button id="up" class="btn btn-warning m-2 text-white" style="display: none;" onclick="scrollUp()"></i></button>


    </div>

    <div id="chat_windowFooter" class="position-sticky bottom-0 row gap-2 col-md-auto p-0 mb-1 m-auto">
        <div id="feedback" class=' col-md-6 m-auto container d-none'></div>
        <div class="col-12 d-flex mx-auto">
            <div class="col-auto m-auto">

                <button id="down" class="btn animate__animated animate__zoomIn" style="display: none;" onclick="scrollDown()">
                    <strong><i class="bi bi-arrow-down"></i></strong>
                    <span id="notifCount" class="btn btn-danger">0</span>
                </button>
            </div>
        <!-- reply -->
            <div class="col">
                
                <div id="file-input_res" class="backdrop-blur-chat-bg col-12 message overflow-x-auto d-none gap-1" style=" align-items: center; padding: 10px; transform: translateY(0px); display: flex; border-radius: 8px;">
                </div>
                <div class='form-inline row m-auto col col-md-6 m-2 rounded-5' style='display:none;     flex-wrap: wrap;'>
                    <div id="replyBox" class="card shadow col-md-12 message hide d-flex" style=" align-items: center; justify-content: space-between; padding: 10px;">
                        <h6 style="margin: 0; font-style: italic; font-size: 14px; text-align: start;"></h6>
                        <div style="flex: 1; margin-left: 10px; text-overflow: ellipsis; overflow: hidden; white-space: nowrap; " id="replyMessageContent">
                        </div>
                    </div>

                    <!-- ------------------ -->
                    <div class="col d-flex messageInputDiv ">
                        <div
                            id="editable-message-text"
                            class=" form-control allow-selection flexible-div "
                            contenteditable="true"
                            role="textbox"
                            dir="auto"
                            tabindex="0"
                            rows="2"
                            aria-label="Message"
                            aria-placeholder="Message ..."
                            autocomplete="on">
                        </div>
                        <div class="button-container col-auto gap-1 d-flex mx-auto">
                            <button id="file-inputBtn" class="btn rounded-pill btn-color border-0 focus-ring-0 fs-5  file-button message_btn">
                                <input type="file" accept="" id="file-input" multiple>
                                <label class="input-label" for="file-input"><i style="    font-size: large;" class="bi btn-color bi-paperclip"></i></label>
                            </button>
                            <button class="btn rounded-pill border-0 focus-ring-0 btn-color send-button message_btn" type="submit" id="button">
                                <i class="bi fs-5 bi-send-fill"></i>
                            </button>
                            <div class="col-auto gap-2 d-flex">
                                <!-- در انتهای footer چت (یک مکان مناسب برای دکمه‌های جدید) -->
                                <div id="recordStatus" class="d-none gap-1 align-items-center">
                                    <span id="timer" class="text-secondary">00:00.00</span>
                                    <span id="blinker" class="blinker"></span>
                                </div>
                                <div id="recordControls" class="d-flex col-auto m-auto btn-group align-items-center"></div>
                                <div class="col-auto m-auto overflow-hidden rounded">

                                    <!-- دکمه ضبط -->  <button id="recordBtn" class="col-auto animate__animated  btn btn-secondary text-white rounded-circle">  <i class="bi bi-mic-fill m-auto"></i> </button>
                                    <!-- دکمه توقف -->  <button id="stopBtn" class="col-auto animate__animated border backdrop-blur shadow text-danger btn   d-none" disabled=""> <i class="bi bi-square-fill m-auto"></i>  </button>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
                
            </div>
        </div>
        
    </div>
    <div id="messageMenu">
        <div class="messageMenuHeader"></div>
        <div class="messageMenubody"></div>
    </div>

</div>

    <script  src='../socket_conn.js'></script>
    <script  src='../chat2.js'></script>
    <script src='../roomManagement.js' defer></script>
    <script src="../setting.js" defer></script>

    <%-include('partials/footer.ejs')%>
        </body>

        </html>
 